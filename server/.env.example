PORT=3001
CLIENT_ORIGIN=http://localhost:5173
JWT_SECRET=change-this-to-a-long-random-string
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password

# Neon Postgres — get this from your Neon project dashboard
# (use the "pooled connection" string; the Neon serverless driver talks to
# it over HTTP, so this works the same locally and on Vercel).
DATABASE_URL=postgresql://user:password@ep-example-123456.us-east-2.aws.neon.tech/neondb?sslmode=require

# Vercel Blob (image uploads) — from Vercel dashboard → Storage → Blob →
# create a store → .env.local tab. On Vercel deployments this is injected
# automatically once a Blob store is connected to the project; you only need
# to set it manually for local dev.
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_placeholder_token

# Contact form email (via Resend — https://resend.com)
# Placeholder values for now; swap in the real Resend API key and the
# client's actual inbox/sending addresses once that account exists.
RESEND_API_KEY=re_placeholder_api_key
CONTACT_TO_EMAIL=owner@example.com
CONTACT_FROM_EMAIL=MAMAJ Website <onboarding@resend.dev>
